<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MeetKit</title>
<meta name="description" content="Secure group video calls powered by LiveKit." />
<script src="/static/livekit-client.umd.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

<style>
/* ══════════════════════════════════════════════════
   TOKENS
══════════════════════════════════════════════════ */
:root {
  --bg:          #111111;
  --surface:     #1a1a1a;
  --surface2:    #222222;
  --surface3:    #2d2d2d;
  --surface4:    #363636;
  --border:      rgba(255,255,255,0.08);
  --border2:     rgba(255,255,255,0.14);
  --text:        #f1f1f1;
  --text2:       #a0a0a0;
  --text3:       #666666;
  --accent:      #2977d1;
  --accent-h:    #3486e3;
  --success:     #22c55e;
  --danger:      #ef4444;
  --danger-h:    #dc2626;
  --warn:        #f59e0b;
  --overlay-bg:  rgba(0,0,0,0.85);
  --tile-radius: 10px;
  --ctrl-h:      72px;
  --font:        'Inter', system-ui, -apple-system, sans-serif;
}

/* ══════════════════════════════════════════════════
   RESET
══════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--font);
  font-size: 14px;
  -webkit-font-smoothing: antialiased;
}
button { font-family: var(--font); cursor: pointer; border: none; outline: none; }
input  { font-family: var(--font); outline: none; border: none; }

/* ══════════════════════════════════════════════════
   PRE-JOIN SCREEN
══════════════════════════════════════════════════ */
#lobby {
  position: fixed; inset: 0; z-index: 100;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg);
  padding: 1.5rem;
  animation: fadeUp .35s ease both;
}

.pj-wrap {
  display: flex;
  gap: 2.5rem;
  align-items: stretch;
  width: 100%;
  max-width: 900px;
}

/* Camera preview pane */
.pj-preview {
  flex: 1;
  min-width: 0;
  background: #000;
  border-radius: 16px;
  overflow: hidden;
  position: relative;
  aspect-ratio: 16/9;
}

.pj-preview video {
  width: 100%; height: 100%;
  object-fit: cover;
  transform: scaleX(-1);   /* mirror self-view */
}

.pj-cam-off {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: .75rem; color: var(--text2);
  font-size: .82rem;
}
.pj-cam-off .av-icon { font-size: 2.5rem; opacity: .35; }

.pj-preview-controls {
  position: absolute; bottom: 1rem; left: 50%;
  translate: -50% 0;
  display: flex; gap: .6rem;
}

.pj-pill-btn {
  height: 38px;
  padding: 0 1rem;
  border-radius: 999px;
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.12);
  color: var(--text);
  font-size: .78rem;
  font-weight: 500;
  display: flex; align-items: center; gap: .4rem;
  transition: background .15s;
}
.pj-pill-btn:hover { background: rgba(255,255,255,.12); }
.pj-pill-btn.off   { background: rgba(239,68,68,.2); border-color: rgba(239,68,68,.3); color: var(--danger); }

/* Join form pane */
.pj-form {
  width: 320px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 1.4rem;
}

.pj-logo {
  display: flex; align-items: center; gap: .65rem;
}
.pj-logo-mark {
  width: 36px; height: 36px; border-radius: 9px;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem;
}
.pj-logo h1 {
  font-size: 1.35rem; font-weight: 700;
  letter-spacing: -.4px; color: var(--text);
}

.pj-section { display: flex; flex-direction: column; gap: .8rem; }
.pj-section-title { font-size: .7rem; font-weight: 600; letter-spacing: .7px; text-transform: uppercase; color: var(--text3); }

.pj-field { display: flex; flex-direction: column; gap: .35rem; }
.pj-field label { font-size: .78rem; font-weight: 500; color: var(--text2); }

.pj-input {
  width: 100%;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 9px;
  padding: .7rem .9rem;
  color: var(--text);
  font-size: .88rem;
  transition: border-color .18s, box-shadow .18s;
}
.pj-input:hover  { border-color: var(--border2); }
.pj-input:focus  { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(41,119,209,.2); }
.pj-input::placeholder { color: var(--text3); }

/* Device selector */
.pj-device-select {
  position: relative;
}
.pj-device-select select {
  width: 100%;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 9px;
  padding: .62rem .9rem;
  padding-right: 2.2rem;
  color: var(--text2);
  font-family: var(--font);
  font-size: .82rem;
  cursor: pointer;
  appearance: none;
  transition: border-color .18s;
}
.pj-device-select select:hover  { border-color: var(--border2); }
.pj-device-select select:focus  { border-color: var(--accent); outline: none; }
.pj-device-select select option { background: var(--surface2); color: var(--text); }
.pj-device-select::after {
  content: '▾';
  position: absolute; right: .8rem; top: 50%; translate: 0 -50%;
  color: var(--text3); pointer-events: none; font-size: .75rem;
}

/* Join button */
.btn-join {
  width: 100%;
  padding: .82rem;
  border-radius: 10px;
  background: var(--accent);
  color: #fff;
  font-size: .9rem;
  font-weight: 600;
  letter-spacing: .1px;
  transition: background .15s, transform .12s, box-shadow .15s;
  box-shadow: 0 2px 12px rgba(41,119,209,.4);
  position: relative; overflow: hidden;
}
.btn-join:hover  { background: var(--accent-h); transform: translateY(-1px); box-shadow: 0 4px 18px rgba(41,119,209,.45); }
.btn-join:active { transform: translateY(0); }
.btn-join:disabled { opacity: .45; cursor: not-allowed; transform: none; box-shadow: none; }
.btn-join .spinner {
  display: none; width: 16px; height: 16px;
  border: 2px solid rgba(255,255,255,.3); border-top-color: #fff;
  border-radius: 50%; animation: spin .6s linear infinite; margin: 0 auto;
}
.btn-join.loading .btn-text { display: none; }
.btn-join.loading .spinner  { display: block; }

#error-msg {
  padding: .6rem .8rem;
  background: rgba(239,68,68,.1);
  border: 1px solid rgba(239,68,68,.22);
  border-radius: 8px; color: #fca5a5;
  font-size: .78rem; line-height: 1.5;
  display: none;
}

/* Divider in form */
.pj-divider {
  height: 1px; background: var(--border);
  margin: .2rem 0;
}

/* ══════════════════════════════════════════════════
   MEETING ROOM
══════════════════════════════════════════════════ */
#room {
  display: none;
  position: fixed; inset: 0; z-index: 50;
  flex-direction: column;
  background: var(--bg);
}

/* ─── Top Bar ─────────────────────────────────── */
.room-header {
  position: absolute; top: 0; left: 0; right: 0;
  height: 52px; z-index: 30;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 1rem;
  background: linear-gradient(180deg, rgba(0,0,0,.7) 0%, transparent 100%);
  pointer-events: none;
}
.room-header > * { pointer-events: auto; }

.room-info {
  display: flex; align-items: center; gap: .55rem;
}
.room-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--success); box-shadow: 0 0 6px var(--success);
  animation: pulse 2s ease-in-out infinite;
}
.room-name {
  font-weight: 600; font-size: .84rem; color: var(--text);
}
.participant-count {
  font-size: .72rem; font-weight: 500; color: rgba(255,255,255,.5);
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 20px; padding: .15rem .55rem;
}

.btn-leave {
  height: 32px; padding: 0 .9rem;
  border-radius: 7px;
  background: rgba(239,68,68,.18);
  border: 1px solid rgba(239,68,68,.28);
  color: var(--danger);
  font-size: .78rem; font-weight: 600;
  transition: background .15s;
}
.btn-leave:hover { background: rgba(239,68,68,.28); }

/* ─── Video Stage (full screen) ─────────────────── */
.video-stage {
  position: absolute; inset: 0;
  padding: 8px 8px calc(var(--ctrl-h) + 16px) 8px;
  display: flex; align-items: center; justify-content: center;
}

/* ─── Video Grid ────────────────────────────────── */
.video-grid {
  width: 100%; height: 100%;
  display: grid;
  gap: 6px;
  grid-template-columns: 1fr;
  grid-template-rows: 1fr;
  align-items: center;
  justify-items: center;
}

/* ─── Participant Tile ──────────────────────────── */
.participant-tile {
  width: 100%; height: 100%;
  background: #1e1e1e;
  border-radius: var(--tile-radius);
  position: relative;
  overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  transition: box-shadow .2s ease;
}

.participant-tile.speaking {
  box-shadow: 0 0 0 2.5px var(--success), 0 0 16px rgba(34,197,94,.2);
}

.participant-tile video {
  width: 100%; height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
  display: none;
}
.participant-tile.has-video video { display: block; }
.participant-tile.has-video .video-off-placeholder { display: none; }

/* Cam-off avatar */
.video-off-placeholder {
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: .75rem; width: 100%; height: 100%;
  background: #1a1a1a;
}

.avatar {
  width: 72px; height: 72px; border-radius: 50%;
  background: linear-gradient(135deg, #2977d1 0%, #6d28d9 100%);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.65rem; font-weight: 700; color: #fff;
  flex-shrink: 0;
}

/* Tile overlay gradient */
.participant-tile::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 60px;
  background: linear-gradient(0deg, rgba(0,0,0,.65) 0%, transparent 100%);
  pointer-events: none;
}

/* Bottom name bar */
.tile-name {
  position: absolute; bottom: .5rem; left: .6rem;
  display: flex; align-items: center; gap: .35rem;
  font-size: .76rem; font-weight: 500; color: #fff;
  z-index: 2; max-width: calc(100% - 5rem);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.muted-icon { font-size: .68rem; color: var(--danger); flex-shrink: 0; }

/* YOU badge */
.local-badge {
  position: absolute; top: .55rem; left: .55rem;
  background: rgba(41,119,209,.25);
  border: 1px solid rgba(41,119,209,.4);
  color: #74b3f5;
  border-radius: 5px; padding: .1rem .45rem;
  font-size: .63rem; font-weight: 700; letter-spacing: .4px; z-index: 2;
}

/* ─── Waiting overlay on remote tiles ─────────── */
.waiting-overlay {
  position: absolute; inset: 0;
  background: rgba(0,0,0,.5);
  backdrop-filter: blur(4px);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: .75rem; z-index: 5;
}
.waiting-overlay .pulse-ring {
  width: 48px; height: 48px; border-radius: 50%;
  border: 1.5px solid var(--success);
  animation: pulseRing 1.5s ease-out infinite;
}
.waiting-overlay p { font-size: .76rem; color: rgba(255,255,255,.45); }

/* ─── Controls Bar (floating pill) ─────────────── */
.controls {
  position: absolute;
  bottom: 16px; left: 50%; translate: -50% 0;
  height: var(--ctrl-h);
  z-index: 30;
  display: flex; align-items: center; gap: .5rem;
  padding: 0 1.2rem;
  background: rgba(26,26,26,.92);
  backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid var(--border2);
  border-radius: 999px;
  box-shadow: 0 8px 32px rgba(0,0,0,.55), 0 1px 0 rgba(255,255,255,.04) inset;
}

/* Divider in controls */
.ctrl-divider {
  width: 1px; height: 28px; background: var(--border2);
  margin: 0 .2rem; flex-shrink: 0;
}

.ctrl-wrap { display: flex; flex-direction: column; align-items: center; gap: .22rem; }

.ctrl-btn {
  width: 46px; height: 46px; border-radius: 50%;
  background: var(--surface3);
  border: 1px solid var(--border);
  color: var(--text); font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, border-color .15s, transform .12s;
  flex-shrink: 0;
}
.ctrl-btn:hover  { background: var(--surface4); border-color: var(--border2); transform: scale(1.07); }
.ctrl-btn:active { transform: scale(.94); }
.ctrl-btn.off {
  background: rgba(239,68,68,.15);
  border-color: rgba(239,68,68,.3);
  color: var(--danger);
}
.ctrl-btn.off:hover { background: rgba(239,68,68,.22); }
.ctrl-btn.danger {
  width: 50px; height: 50px; font-size: .9rem;
  background: var(--danger);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 3px 12px rgba(239,68,68,.4);
}
.ctrl-btn.danger:hover { background: var(--danger-h); transform: scale(1.07); border-color: transparent; }

.ctrl-label { font-size: .6rem; color: var(--text3); font-weight: 500; white-space: nowrap; }

/* Chat toggle btn */
.ctrl-btn.chat-active {
  background: rgba(41,119,209,.2);
  border-color: rgba(41,119,209,.4);
  color: #74b3f5;
}

/* Unread badge */
.unread-badge {
  position: absolute; top: -3px; right: -3px;
  background: var(--danger); color: #fff;
  width: 16px; height: 16px; border-radius: 50%;
  font-size: .6rem; font-weight: 700;
  display: none; align-items: center; justify-content: center;
  pointer-events: none;
}
.unread-badge.show { display: flex; }

/* ── Room body layout ─────────────────────────── */
.room-main {
  flex: 1;
  display: flex;
  min-height: 0;
  position: relative;
}
.video-stage { flex: 1; }

/* ══════════════════════════════════════════════════
   CHAT PANEL (slide-over overlay, not shifting grid)
══════════════════════════════════════════════════ */
.chat-panel {
  position: absolute; top: 0; right: 0; bottom: 0;
  width: 320px; z-index: 25;
  background: rgba(18,18,18,.97);
  backdrop-filter: blur(20px);
  border-left: 1px solid var(--border2);
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform .28s cubic-bezier(.4,0,.2,1);
  box-shadow: -8px 0 30px rgba(0,0,0,.4);
}
.chat-panel.open { transform: translateX(0); }

.chat-header {
  height: 52px; flex-shrink: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 1rem;
  border-bottom: 1px solid var(--border);
}
.chat-header-left { display: flex; align-items: center; gap: .5rem; }
.chat-header h3 { font-size: .84rem; font-weight: 600; color: var(--text); }
.chat-header-pill {
  font-size: .65rem; font-weight: 600; color: var(--text3);
  background: var(--surface2); border-radius: 20px;
  padding: .1rem .5rem; border: 1px solid var(--border);
}
.chat-close {
  width: 28px; height: 28px; border-radius: 6px;
  background: none; color: var(--text3); font-size: 1rem;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, color .15s;
}
.chat-close:hover { background: var(--surface2); color: var(--text); }

.chat-messages {
  flex: 1; overflow-y: auto; padding: .75rem;
  display: flex; flex-direction: column; gap: .4rem;
  scroll-behavior: smooth;
}
.chat-messages::-webkit-scrollbar { width: 3px; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 3px; }

.chat-empty {
  margin: auto; text-align: center;
  color: var(--text3); font-size: .8rem; line-height: 1.6;
}

/* System event messages */
.chat-sys-msg {
  text-align: center; font-size: .7rem; color: var(--text3);
  padding: .2rem 0; font-style: italic;
}

/* Chat bubble */
.chat-msg {
  display: flex; flex-direction: column; gap: .15rem;
  max-width: 92%;
  animation: msgIn .18s ease;
}
.chat-msg.self { align-self: flex-end; }
.chat-msg.other { align-self: flex-start; }

.chat-meta {
  font-size: .65rem; color: var(--text3); font-weight: 500;
  display: flex; gap: .35rem; align-items: baseline;
  padding: 0 .35rem;
}
.chat-msg.self .chat-meta { flex-direction: row-reverse; }

.chat-sender { color: var(--accent-h); font-weight: 600; }
.chat-msg.self .chat-sender { color: #a78bfa; }

.chat-text {
  padding: .5rem .7rem;
  border-radius: 12px;
  font-size: .83rem; line-height: 1.45;
  word-break: break-word; white-space: pre-wrap;
  color: var(--text);
}
.chat-msg.self  .chat-text { background: #2977d1; border-bottom-right-radius: 3px; }
.chat-msg.other .chat-text { background: var(--surface3); border-bottom-left-radius: 3px; }

/* Chat input */
.chat-input-wrap {
  flex-shrink: 0; padding: .65rem .75rem;
  border-top: 1px solid var(--border);
  display: flex; align-items: flex-end; gap: .5rem;
}
.chat-input {
  flex: 1; min-width: 0;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 10px;
  padding: .55rem .75rem;
  color: var(--text);
  font-size: .82rem; line-height: 1.4;
  resize: none; max-height: 90px; overflow-y: auto;
  transition: border-color .18s;
}
.chat-input:focus { border-color: var(--accent); }
.chat-input::placeholder { color: var(--text3); }

.chat-send {
  width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
  background: var(--accent);
  color: #fff; font-size: .85rem;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, transform .12s;
}
.chat-send:hover  { background: var(--accent-h); transform: scale(1.06); }
.chat-send:active { transform: scale(.94); }
.chat-send:disabled { opacity: .35; cursor: not-allowed; transform: none; }

/* ══════════════════════════════════════════════════
   TOAST
══════════════════════════════════════════════════ */
#toast {
  position: fixed; bottom: calc(var(--ctrl-h) + 28px); left: 50%;
  translate: -50% 0;
  background: rgba(30,30,30,.95);
  backdrop-filter: blur(8px);
  border: 1px solid var(--border2);
  border-radius: 8px; padding: .45rem 1rem;
  font-size: .78rem; font-weight: 500; color: var(--text2);
  opacity: 0; transform: translateY(8px);
  transition: opacity .25s, transform .25s;
  pointer-events: none; z-index: 999;
  white-space: nowrap; box-shadow: 0 6px 20px rgba(0,0,0,.5);
}
#toast.show { opacity: 1; transform: translateY(0); }

/* ══════════════════════════════════════════════════
   ANIMATIONS
══════════════════════════════════════════════════ */
@keyframes fadeUp     { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:none} }
@keyframes spin       { to{transform:rotate(360deg)} }
@keyframes pulse      { 0%,100%{opacity:1} 50%{opacity:.3} }
@keyframes pulseRing  { 0%{transform:scale(.75);opacity:1} 100%{transform:scale(1.5);opacity:0} }
@keyframes msgIn      { from{opacity:0;transform:translateY(5px)} to{opacity:1;transform:none} }

/* ══════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════ */
@media (max-width: 820px) {
  .pj-wrap { flex-direction: column; align-items: center; gap: 1.5rem; }
  .pj-preview { width: 100%; max-width: 480px; }
  .pj-form { width: 100%; max-width: 480px; }
  .chat-panel { width: 100%; border-left: none; border-top: 1px solid var(--border2); }
}
@media (max-width: 480px) {
  .controls { padding: 0 .85rem; gap: .35rem; }
  .ctrl-btn { width: 42px; height: 42px; font-size: .9rem; }
  .ctrl-btn.danger { width: 46px; height: 46px; }
  .room-name { display: none; }
}
</style>
</head>
<body>

<!-- ══════════════════════════════════════════════
     PRE-JOIN LOBBY
══════════════════════════════════════════════ -->
<div id="lobby">
  <div class="pj-wrap">

    <!-- Camera Preview -->
    <div class="pj-preview" id="pj-preview-wrap">
      <video id="pj-video" autoplay playsinline muted></video>
      <div class="pj-cam-off" id="pj-cam-off">
        <span class="av-icon">📷</span>
        <span>Camera is off</span>
      </div>
      <!-- Quick toggle buttons over preview -->
      <div class="pj-preview-controls">
        <button class="pj-pill-btn" id="pj-mic-btn" onclick="pjToggleMic()">🎙️ <span id="pj-mic-label">Mic On</span></button>
        <button class="pj-pill-btn" id="pj-cam-btn" onclick="pjToggleCam()">📹 <span id="pj-cam-label">Cam On</span></button>
      </div>
    </div>

    <!-- Join Form -->
    <div class="pj-form">
      <div class="pj-logo">
        <div class="pj-logo-mark">🎥</div>
        <h1>MeetKit</h1>
      </div>

      <div class="pj-section">
        <div class="pj-section-title">Join a Room</div>

        <div class="pj-field">
          <label for="room-input">Room name</label>
          <input id="room-input" class="pj-input" type="text"
            placeholder="e.g. team-standup" autocomplete="off" />
        </div>

        <div class="pj-field">
          <label for="name-input">Your name</label>
          <input id="name-input" class="pj-input" type="text"
            placeholder="e.g. Alice" autocomplete="off" />
        </div>
      </div>

      <div class="pj-divider"></div>

      <div class="pj-section">
        <div class="pj-section-title">Devices</div>

        <div class="pj-field">
          <label>Camera</label>
          <div class="pj-device-select">
            <select id="pj-cam-select" onchange="pjSwitchCam()"></select>
          </div>
        </div>

        <div class="pj-field">
          <label>Microphone</label>
          <div class="pj-device-select">
            <select id="pj-mic-select"></select>
          </div>
        </div>
      </div>

      <button class="btn-join" id="join-btn" onclick="joinRoom()">
        <span class="btn-text">Join Meeting →</span>
        <div class="spinner"></div>
      </button>

      <div id="error-msg"></div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════════════
     MEETING ROOM
══════════════════════════════════════════════ -->
<div id="room">

  <!-- Floating top bar -->
  <div class="room-header">
    <div class="room-info">
      <div class="room-dot"></div>
      <span class="room-name" id="room-title"></span>
      <span class="participant-count" id="p-count">1</span>
    </div>
    <button class="btn-leave" onclick="leaveRoom()">Leave</button>
  </div>

  <div class="room-main">
    <!-- Full-screen video stage -->
    <div class="video-stage">
      <div class="video-grid" id="video-grid"></div>
    </div>

    <!-- Chat slide-over panel -->
    <aside class="chat-panel" id="chat-panel">
      <div class="chat-header">
        <div class="chat-header-left">
          <h3>Chat</h3>
          <span class="chat-header-pill" id="chat-title">Room</span>
        </div>
        <button class="chat-close" onclick="toggleChat()">✕</button>
      </div>

      <div class="chat-messages" id="chat-messages">
        <div class="chat-empty" id="chat-empty">No messages yet.<br>Say hello to the room.</div>
      </div>

      <div class="chat-input-wrap">
        <textarea id="chat-input" class="chat-input" rows="1"
          placeholder="Send a message…"
          oninput="autoResizeChat(this)"></textarea>
        <button id="chat-send" class="chat-send" onclick="sendChatMessage()" title="Send">➤</button>
      </div>
    </aside>
  </div>

  <!-- Floating pill controls -->
  <div class="controls">
    <div class="ctrl-wrap">
      <button class="ctrl-btn" id="mic-btn" onclick="toggleMic()">🎙️</button>
      <div class="ctrl-label" id="mic-label">Mute</div>
    </div>
    <div class="ctrl-wrap">
      <button class="ctrl-btn" id="cam-btn" onclick="toggleCam()">📹</button>
      <div class="ctrl-label" id="cam-label">Video</div>
    </div>

    <div class="ctrl-divider"></div>

    <div class="ctrl-wrap" style="position:relative;">
      <button class="ctrl-btn" id="chat-toggle-btn" onclick="toggleChat()">💬</button>
      <span class="unread-badge" id="unread-badge"></span>
      <div class="ctrl-label">Chat</div>
    </div>

    <div class="ctrl-divider"></div>

    <div class="ctrl-wrap">
      <button class="ctrl-btn danger" onclick="leaveRoom()">📞</button>
      <div class="ctrl-label">Leave</div>
    </div>
  </div>

</div>

<!-- Toast -->
<div id="toast"></div>

<!-- ══════════════════════════════════════════════
     JAVASCRIPT
══════════════════════════════════════════════ -->
<script>
/* ═══════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════ */
let lkRoom       = null;
let micEnabled   = true;
let camEnabled   = true;
const tiles      = {};
const participantNames = {};
const textEncoder = new TextEncoder();
const textDecoder = new TextDecoder();
let localDisplayName = '';

// Pre-join state
let pjStream     = null;
let pjMicOn      = true;
let pjCamOn      = true;

// Chat state
let chatOpen     = false;
let unreadCount  = 0;

/* ═══════════════════════════════════════════════
   HELPERS
═══════════════════════════════════════════════ */
const $ = id => document.getElementById(id);

function showToast(msg, ms = 2600) {
  const t = $('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer = setTimeout(() => t.classList.remove('show'), ms);
}

function showError(msg) {
  const el = $('error-msg');
  el.textContent = msg;
  el.style.display = 'block';
}
function hideError() { $('error-msg').style.display = 'none'; }

function setJoinLoading(on) {
  const btn = $('join-btn');
  btn.classList.toggle('loading', on);
  btn.disabled = on;
}

function getInitials(name = '?') {
  return (name || '?').split(' ').map(w => w[0]).join('').toUpperCase().slice(0,2) || '?';
}

function fmtTime(d) {
  return new Date(d).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
}

/* ═══════════════════════════════════════════════
   GRID LAYOUT
   Fills available space like Google Meet / Zoom:
   compute optimal columns so tiles are as large
   as possible without scrolling.
═══════════════════════════════════════════════ */
function applyGridColumns() {
  const grid  = $('video-grid');
  const count = Object.keys(tiles).length;
  if (!count) return;

  let cols;
  if      (count === 1)  cols = 1;
  else if (count === 2)  cols = 2;
  else if (count <= 4)   cols = 2;
  else if (count <= 6)   cols = 3;
  else if (count <= 9)   cols = 3;
  else if (count <= 12)  cols = 4;
  else                   cols = 4;

  const rows = Math.ceil(count / cols);
  grid.style.gridTemplateColumns = `repeat(${cols}, 1fr)`;
  grid.style.gridTemplateRows    = `repeat(${rows}, 1fr)`;
}

function updateParticipantCount() {
  const n = lkRoom ? lkRoom.remoteParticipants.size + 1 : 1;
  $('p-count').textContent = `${n} ${n === 1 ? 'participant' : 'participants'}`;
  applyGridColumns();
}

/* ═══════════════════════════════════════════════
   TILE MANAGEMENT
═══════════════════════════════════════════════ */
function createTile(sid, name, isLocal = false) {
  participantNames[sid] = name;

  const tile = document.createElement('div');
  tile.className = 'participant-tile';
  tile.id = `tile-${sid}`;
  tile.innerHTML = `
    <video id="vid-${sid}" autoplay playsinline ${isLocal ? 'muted' : ''}></video>
    <div class="video-off-placeholder" id="ph-${sid}">
      <div class="avatar">${getInitials(name)}</div>
    </div>
    <div class="tile-name" id="name-${sid}">
      <span>${escHtml(name)}</span>
      <span class="muted-icon" id="muted-${sid}" style="display:none">🔇</span>
    </div>
    ${isLocal ? '<span class="local-badge">YOU</span>' : ''}
  `;

  if (!isLocal) {
    tile.innerHTML += `
      <div class="waiting-overlay" id="wait-${sid}">
        <div class="pulse-ring"></div>
        <p>${escHtml(name)} joining…</p>
      </div>`;
  }

  $('video-grid').appendChild(tile);
  tiles[sid] = tile;
  applyGridColumns();
  return tile;
}

function removeTile(sid) {
  const t = tiles[sid];
  if (t) { t.remove(); delete tiles[sid]; }
  delete participantNames[sid];
  applyGridColumns();
}

function attachTrack(sid, track) {
  const vid  = $(`vid-${sid}`);
  const ph   = $(`ph-${sid}`);
  const wait = $(`wait-${sid}`);
  const tile = $(`tile-${sid}`);

  if (track.kind === 'video') {
    if (vid) {
      track.attach(vid);
      tile && tile.classList.add('has-video');
      if (wait) wait.style.display = 'none';
    }
  }
  if (track.kind === 'audio' && !track.isLocal) {
    const audio = track.attach();
    audio.id = `aud-${sid}-${Date.now()}`;
    document.body.appendChild(audio);
  }
}

function detachTrack(sid, track) {
  const tile = $(`tile-${sid}`);
  if (track.kind === 'video') {
    const vid  = $(`vid-${sid}`);
    if (vid)  track.detach(vid);
    tile && tile.classList.remove('has-video');
    const wait = $(`wait-${sid}`);
    if (wait && !isPublishing(sid)) wait.style.display = 'flex';
    return;
  }
  if (track.kind === 'audio') {
    track.detach().forEach(el => el.remove());
  }
}

function isPublishing(sid) {
  for (const [, p] of lkRoom.remoteParticipants) {
    if (p.sid === sid) {
      for (const [, pub] of p.trackPublications) {
        if (pub.isSubscribed && pub.kind === 'video') return true;
      }
    }
  }
  return false;
}

/* ═══════════════════════════════════════════════
   PRE-JOIN CAMERA PREVIEW
═══════════════════════════════════════════════ */
async function initPreview() {
  try {
    pjStream = await navigator.mediaDevices.getUserMedia({ video: true, audio: true });
    const vid = $('pj-video');
    vid.srcObject = pjStream;
    $('pj-cam-off').style.display = 'none';
    await populateDevices();
  } catch (e) {
    $('pj-cam-off').style.display = 'flex';
    console.warn('Preview unavailable:', e.message);
  }
}

async function populateDevices() {
  try {
    const devices = await navigator.mediaDevices.enumerateDevices();

    const camSel = $('pj-cam-select');
    const micSel = $('pj-mic-select');
    camSel.innerHTML = ''; micSel.innerHTML = '';

    devices.filter(d => d.kind === 'videoinput').forEach((d, i) => {
      camSel.appendChild(new Option(d.label || `Camera ${i+1}`, d.deviceId));
    });
    devices.filter(d => d.kind === 'audioinput').forEach((d, i) => {
      micSel.appendChild(new Option(d.label || `Mic ${i+1}`, d.deviceId));
    });
  } catch(e) { /* permissions not yet granted */ }
}

function pjToggleMic() {
  pjMicOn = !pjMicOn;
  if (pjStream) {
    pjStream.getAudioTracks().forEach(t => t.enabled = pjMicOn);
  }
  const btn = $('pj-mic-btn');
  $('pj-mic-label').textContent = pjMicOn ? 'Mic On' : 'Mic Off';
  btn.classList.toggle('off', !pjMicOn);
  btn.childNodes[0].nodeValue = pjMicOn ? '🎙️ ' : '🔇 ';
}

function pjToggleCam() {
  pjCamOn = !pjCamOn;
  if (pjStream) {
    pjStream.getVideoTracks().forEach(t => t.enabled = pjCamOn);
  }
  const btn = $('pj-cam-btn');
  $('pj-cam-label').textContent = pjCamOn ? 'Cam On' : 'Cam Off';
  btn.classList.toggle('off', !pjCamOn);
  btn.childNodes[0].nodeValue = pjCamOn ? '📹 ' : '🚫 ';
  $('pj-cam-off').style.display = pjCamOn ? 'none' : 'flex';
}

async function pjSwitchCam() {
  const deviceId = $('pj-cam-select').value;
  if (!deviceId || !pjStream) return;
  try {
    const newStream = await navigator.mediaDevices.getUserMedia({
      video: { deviceId: { exact: deviceId } },
      audio: false,
    });
    const [newTrack] = newStream.getVideoTracks();
    const [oldTrack] = pjStream.getVideoTracks();
    pjStream.removeTrack(oldTrack);
    oldTrack.stop();
    pjStream.addTrack(newTrack);
    $('pj-video').srcObject = pjStream;
  } catch(e) { console.warn('Camera switch failed:', e); }
}

function stopPreview() {
  if (pjStream) {
    pjStream.getTracks().forEach(t => t.stop());
    pjStream = null;
  }
}

/* ═══════════════════════════════════════════════
   JOIN
═══════════════════════════════════════════════ */
async function joinRoom() {
  hideError();
  const roomName = $('room-input').value.trim();
  const userName = $('name-input').value.trim();
  if (!roomName) { showError('Please enter a room name.'); return; }
  if (!userName) { showError('Please enter your name.'); return; }
  localDisplayName = userName;
  setJoinLoading(true);

  try {
    const res = await fetch('/token', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ room_name: roomName, participant_name: userName }),
    });
    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.detail || `Server error ${res.status}`);
    }
    const { token, livekit_url } = await res.json();

    lkRoom = new LivekitClient.Room({
      adaptiveStream: true,
      dynacast: true,
      videoCaptureDefaults: { resolution: LivekitClient.VideoPresets.h720.resolution },
    });

    wireRoomEvents();
    await lkRoom.connect(livekit_url, token);

    // Stop preview, enable real tracks
    stopPreview();
    await lkRoom.localParticipant.enableCameraAndMicrophone();
    micEnabled = pjMicOn;
    camEnabled = pjCamOn;
    if (!micEnabled) await lkRoom.localParticipant.setMicrophoneEnabled(false);
    if (!camEnabled) await lkRoom.localParticipant.setCameraEnabled(false);

    // Switch UI
    $('lobby').style.display = 'none';
    $('room').style.display  = 'flex';
    $('room-title').textContent = roomName;
    $('chat-title').textContent = roomName;
    $('chat-send').disabled = false;

    // Local tile
    const lsid = lkRoom.localParticipant.sid;
    createTile(lsid, userName, true);
    syncLocalMedia();

    // Already-present remotes
    for (const [, p] of lkRoom.remoteParticipants) onParticipantConnected(p);

    // Sync control button states
    updateControlState();
    updateParticipantCount();
    showToast('✅ Connected');

  } catch (err) {
    showError(err.message || 'Could not connect. Check credentials.');
    console.error(err);
  } finally {
    setJoinLoading(false);
  }
}

function syncLocalMedia() {
  const lsid = lkRoom.localParticipant.sid;
  const camPub = lkRoom.localParticipant.getTrackPublication(LivekitClient.Track.Source.Camera);
  if (camPub?.videoTrack) attachTrack(lsid, camPub.videoTrack);
}

function updateControlState() {
  const micBtn = $('mic-btn');
  micBtn.classList.toggle('off', !micEnabled);
  micBtn.textContent = micEnabled ? '🎙️' : '🔇';
  $('mic-label').textContent = micEnabled ? 'Mute' : 'Unmute';

  const camBtn = $('cam-btn');
  camBtn.classList.toggle('off', !camEnabled);
  camBtn.textContent = camEnabled ? '📹' : '🚫';
  $('cam-label').textContent = camEnabled ? 'Stop Video' : 'Start Video';
}

/* ═══════════════════════════════════════════════
   ROOM EVENTS
═══════════════════════════════════════════════ */
function wireRoomEvents() {
  lkRoom
    .on(LivekitClient.RoomEvent.ParticipantConnected, onParticipantConnected)
    .on(LivekitClient.RoomEvent.ParticipantDisconnected, p => {
      removeTile(p.sid);
      updateParticipantCount();
      addSysMsg(`${p.name || p.identity} left`);
      showToast(`${p.name || p.identity} left`);
    })
    .on(LivekitClient.RoomEvent.TrackSubscribed, (track, _pub, participant) => {
      attachTrack(participant.sid, track);
    })
    .on(LivekitClient.RoomEvent.TrackUnsubscribed, (track, _pub, participant) => {
      detachTrack(participant.sid, track);
    })
    .on(LivekitClient.RoomEvent.DataReceived, onDataReceived)
    .on(LivekitClient.RoomEvent.LocalTrackPublished, pub => {
      if (pub.kind === 'video' && pub.videoTrack)
        attachTrack(lkRoom.localParticipant.sid, pub.videoTrack);
    })
    .on(LivekitClient.RoomEvent.ActiveSpeakersChanged, speakers => {
      document.querySelectorAll('.participant-tile').forEach(t => t.classList.remove('speaking'));
      speakers.forEach(s => {
        const t = $(`tile-${s.sid}`);
        if (t) t.classList.add('speaking');
      });
    })
    .on(LivekitClient.RoomEvent.TrackMuted, (pub, participant) => {
      if (pub.kind === 'audio') {
        const ico = $(`muted-${participant.sid}`);
        if (ico) ico.style.display = 'inline';
      }
    })
    .on(LivekitClient.RoomEvent.TrackUnmuted, (pub, participant) => {
      if (pub.kind === 'audio') {
        const ico = $(`muted-${participant.sid}`);
        if (ico) ico.style.display = 'none';
      }
    })
    .on(LivekitClient.RoomEvent.Disconnected, () => {
      showToast('Disconnected');
      resetToLobby();
    });
}

function onParticipantConnected(participant) {
  createTile(participant.sid, participant.name || participant.identity, false);
  updateParticipantCount();
  addSysMsg(`${participant.name || participant.identity} joined`);
  showToast(`👋 ${participant.name || participant.identity} joined`);
  for (const [, pub] of participant.trackPublications) {
    if (pub.isSubscribed && pub.track) attachTrack(participant.sid, pub.track);
  }
}

/* ═══════════════════════════════════════════════
   MEDIA CONTROLS
═══════════════════════════════════════════════ */
async function toggleMic() {
  if (!lkRoom) return;
  micEnabled = !micEnabled;
  await lkRoom.localParticipant.setMicrophoneEnabled(micEnabled);
  const ico = $(`muted-${lkRoom.localParticipant.sid}`);
  if (ico) ico.style.display = micEnabled ? 'none' : 'inline';
  updateControlState();
  showToast(micEnabled ? '🎙️ Microphone on' : '🔇 Microphone off');
}

async function toggleCam() {
  if (!lkRoom) return;
  camEnabled = !camEnabled;
  await lkRoom.localParticipant.setCameraEnabled(camEnabled);
  if (camEnabled) {
    const camPub = lkRoom.localParticipant.getTrackPublication(LivekitClient.Track.Source.Camera);
    if (camPub?.videoTrack) attachTrack(lkRoom.localParticipant.sid, camPub.videoTrack);
  } else {
    $(`tile-${lkRoom.localParticipant.sid}`)?.classList.remove('has-video');
  }
  updateControlState();
  showToast(camEnabled ? '📹 Camera on' : '🚫 Camera off');
}

/* ═══════════════════════════════════════════════
   LEAVE
═══════════════════════════════════════════════ */
async function leaveRoom() {
  if (lkRoom) { await lkRoom.disconnect(); lkRoom = null; }
  resetToLobby();
}

function resetToLobby() {
  $('video-grid').innerHTML = '';
  Object.keys(tiles).forEach(k => delete tiles[k]);
  Object.keys(participantNames).forEach(k => delete participantNames[k]);
  $('chat-messages').innerHTML = '<div class="chat-empty" id="chat-empty">No messages yet.<br>Say hello to the room.</div>';
  $('chat-input').value = '';
  $('chat-send').disabled = true;
  chatOpen = false; unreadCount = 0;
  $('chat-panel').classList.remove('open');
  $('chat-toggle-btn').classList.remove('chat-active');
  $('unread-badge').classList.remove('show');
  micEnabled = camEnabled = true;
  localDisplayName = '';
  updateControlState();
  $('room').style.display  = 'none';
  $('lobby').style.display = 'flex';
  // restart preview
  initPreview();
}

/* ═══════════════════════════════════════════════
   CHAT
═══════════════════════════════════════════════ */
function toggleChat() {
  chatOpen = !chatOpen;
  $('chat-panel').classList.toggle('open', chatOpen);
  $('chat-toggle-btn').classList.toggle('chat-active', chatOpen);
  if (chatOpen) {
    unreadCount = 0;
    $('unread-badge').classList.remove('show');
    scrollChat();
    setTimeout(() => $('chat-input').focus(), 300);
  }
}

async function sendChatMessage() {
  if (!lkRoom) return;
  const input = $('chat-input');
  const text  = input.value.trim();
  if (!text) return;

  const message = {
    type: 'chat', text,
    sender: localDisplayName || lkRoom.localParticipant.name || 'You',
    ts: new Date().toISOString(),
  };

  try {
    await publishReliableData(textEncoder.encode(JSON.stringify(message)));
    appendChatMessage({ sender: message.sender, text, isSelf: true, timestamp: message.ts });
    input.value = '';
    input.style.height = '';
    input.focus();
  } catch (e) {
    showToast('⚠️ Could not send message');
  }
}

async function publishReliableData(data) {
  try {
    await lkRoom.localParticipant.publishData(data, { reliable: true });
  } catch (err) {
    const kind = LivekitClient.DataPacket_Kind?.RELIABLE;
    if (kind === undefined) throw err;
    await lkRoom.localParticipant.publishData(data, kind);
  }
}

function onDataReceived(payload, participant) {
  try {
    const parsed = JSON.parse(textDecoder.decode(payload));
    if (!parsed || parsed.type !== 'chat' || !parsed.text) return;
    const sender = parsed.sender || participant?.name || participant?.identity || 'Participant';
    appendChatMessage({ sender, text: String(parsed.text), isSelf: false, timestamp: parsed.ts || new Date() });
  } catch (_) {}
}

function appendChatMessage({ sender, text, isSelf, timestamp }) {
  const list  = $('chat-messages');
  const empty = $('chat-empty');
  if (empty) empty.remove();

  const div = document.createElement('div');
  div.className = `chat-msg ${isSelf ? 'self' : 'other'}`;
  div.innerHTML = `
    <div class="chat-meta">
      <span class="chat-sender">${escHtml(sender)}</span>
      <span>${fmtTime(timestamp)}</span>
    </div>
    <div class="chat-text"></div>
  `;
  div.querySelector('.chat-text').textContent = text;
  list.appendChild(div);
  scrollChat();

  if (!chatOpen && !isSelf) {
    unreadCount++;
    const badge = $('unread-badge');
    badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
    badge.classList.add('show');
  }
}

function addSysMsg(text) {
  const list = $('chat-messages');
  const div  = document.createElement('div');
  div.className = 'chat-sys-msg';
  div.textContent = text;
  list.appendChild(div);
  scrollChat();
}

function scrollChat() {
  const el = $('chat-messages');
  el.scrollTop = el.scrollHeight;
}

function autoResizeChat(el) {
  el.style.height = '';
  el.style.height = Math.min(el.scrollHeight, 90) + 'px';
}

function escHtml(s) {
  return String(s)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ═══════════════════════════════════════════════
   KEYBOARD SHORTCUTS
═══════════════════════════════════════════════ */
document.addEventListener('keydown', e => {
  // Enter to join
  if (e.key === 'Enter' && $('lobby').style.display !== 'none') {
    const focused = document.activeElement;
    if (focused && ['room-input','name-input','pj-cam-select','pj-mic-select'].includes(focused.id)) {
      joinRoom();
    }
  }
});

$('chat-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendChatMessage();
  }
});

/* ═══════════════════════════════════════════════
   BOOT
═══════════════════════════════════════════════ */
initPreview();
</script>
</body>
</html>